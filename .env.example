# LLM
GROQ_API_KEY= #your api key here
LLM_MODEL_NAME=llama-3.3-70b-versatile
LLM_TEMPERATURE=0.0
LLM_MAX_TOKENS=2048

# Embeddings
EMBEDDING_MODEL_NAME=BAAI/bge-large-en-v1.5

# Paths
CORPUS_PATH=data/corpus
FAISS_INDEX_PATH=data/indexes/faiss
BM25_INDEX_PATH=data/indexes/bm25
EMBEDDINGS_PATH=data/embeddings
TELEMETRY_PATH=data/telemetry

# Retrieval
RETRIEVAL_TOP_K=10
VECTOR_WEIGHT=0.5
BM25_WEIGHT=0.5
FUSION_METHOD=rrf

# Confidence
CONFIDENCE_THRESHOLD=0.6

# App
LOG_LEVEL=INFO
APP_NAME=legal-rag
